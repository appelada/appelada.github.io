    background: linear-gradient(135deg, var(--green-light) 0%, var(--green-pale) 100%);
    padding: 60px 0 48px;
  }
  .legal-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
  }
  .legal-hero .update-date {
    font-size: 0.9rem;
    color: #6b7280;
    margin-top: 8px;
  }
  .legal-body {
    padding: 56px 0 72px;
  }
  .legal-body h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    color: #111827;
  }
  .legal-body h2:first-child {
    margin-top: 0;
  }
  .legal-body p, .legal-body li {
    color: #374151;
    line-height: 1.75;
    font-size: 0.97rem;
  }
  .legal-body ul {
    padding-left: 1.4rem;
  }
  .legal-body ul li {
    margin-bottom: 4px;
  }
  .legal-body a {
    color: var(--green);
