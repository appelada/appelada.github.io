<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}Appelada{% endblock %}</title>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-3FQTL6433S"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-3FQTL6433S');
  </script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.441.0/dist/umd/lucide.min.js"></script>
  <style>
    :root {
      --green: #169f48;
      --green-dark: #15803d;
      --green-light: #f0fdf4;
      --green-pale: #d1fae5;
    }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      color: #1a1a1a;
    }

    /* ── Navbar ── */
    .navbar {
      background: #fff;
      border-bottom: 1px solid #e5e7eb;
    }
    .navbar-brand {
      font-weight: 700;
      font-size: 1.4rem;
      color: var(--green) !important;
    }
    .btn-primary-green {
      background: var(--green);
      border-color: var(--green);
      color: #fff;
      font-weight: 600;
    }
    .btn-primary-green:hover {
      background: var(--green-dark);
      border-color: var(--green-dark);
      color: #fff;
    }
    .btn-outline-green {
      border-color: var(--green);
      color: var(--green);
      font-weight: 600;
    }
    .btn-outline-green:hover {
      background: var(--green);
      color: #fff;
    }

    /* ── Footer ── */
    footer {
      background: #111827;
      color: #9ca3af;
      padding: 48px 0 32px;
    }
    footer .brand {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--green);
    }
    footer .tagline {
      font-size: 0.9rem;
      margin-top: 4px;
      color: #6b7280;
    }
    footer a {
      color: #9ca3af;
      text-decoration: none;
      font-size: 0.9rem;
    }
    footer a:hover { color: #fff; }
    footer .footer-links h6 {
      color: #e5e7eb;
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 12px;
    }
    footer .footer-links li { margin-bottom: 6px; }
    footer .divider {
      border-color: #1f2937;
      margin: 32px 0 24px;
    }
    footer .copyright { font-size: 0.85rem; }
  </style>
  {% block pageStyles %}{% endblock %}
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">
      <a class="navbar-brand" href="/">⚽ Appelada</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/#features">Funcionalidades</a></li>
          <li class="nav-item"><a class="nav-link" href="/#screenshots">Capturas de Tela</a></li>
          <li class="nav-item"><a class="nav-link" href="/#pricing">Planos</a></li>
          <li class="nav-item"><a class="nav-link" href="/#how-it-works">Como Funciona</a></li>
        </ul>
        <div class="d-flex gap-2">
          <a href="https://app.appelada.net/#/login" class="btn btn-outline-green btn-sm">Entrar</a>
          <a href="https://app.appelada.net/#/register" class="btn btn-primary-green btn-sm">Começar Grátis</a>
        </div>
      </div>
    </div>
  </nav>

  {% block content %}{% endblock %}

  <!-- Footer -->
  <footer>
    <div class="container">
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="brand">⚽ Appelada</div>
          <p class="tagline mt-1">Sua pelada, organizada.</p>
          <p class="mt-3" style="font-size:0.9rem;">A ferramenta completa para gerenciar sua pelada — do primeiro chute à classificação final.</p>
        </div>
        <div class="col-6 col-lg-2 offset-lg-4 footer-links">
          <h6>Produto</h6>
          <ul class="list-unstyled">
            <li><a href="/#features">Funcionalidades</a></li>
            <li><a href="/#pricing">Planos</a></li>
            <li><a href="/#screenshots">Capturas de Tela</a></li>
          </ul>
        </div>
        <div class="col-6 col-lg-2 footer-links">
          <h6>Legal</h6>
          <ul class="list-unstyled">
            <li><a href="/politica-de-privacidade/">Política de Privacidade</a></li>
            <li><a href="/termos-de-uso/">Termos de Uso</a></li>
            <li><a href="mailto:contato@appelada.net">Contato</a></li>
          </ul>
        </div>
      </div>
      <hr class="divider" />
      <p class="copyright text-center mb-0">&copy; 2026 Appelada. Todos os direitos reservados.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
